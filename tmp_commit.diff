@@ -0,0 +1,20 @@
+import React from 'react';
+import TodoItem from './TodoItem';
+
+function TodoList({ todos, onToggle, onDelete }) {
+  return (
+    <ul className="todo-list">
+      {todos.map((todo) => (
+        <TodoItem
+          key={todo.id}
+          todo={todo}
+          index={todo.originalIndex}
+          onToggle={onToggle}
+          onDelete={onDelete}
+        />
+      ))}
+    </ul>
+  );
+}
+
+export default TodoList;
